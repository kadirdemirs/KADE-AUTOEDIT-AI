# KADE AutoEdit AI — opsiyonel ayarlar. Bu dosyayi .env olarak kopyalayin.

# Meme Bulucu GIF kaynaklari (opsiyonel; yoksa o kaynak atlanir)
TENOR_API_KEY=
GIPHY_API_KEY=

# Imgflip caption uretimi icin (opsiyonel; get_memes aramasi anahtarsiz calisir)
IMGFLIP_USERNAME=
IMGFLIP_PASSWORD=

# FFmpeg yolu override (normalde otomatik bulunur)
# FFMPEG_PATH=
# FFPROBE_PATH=

# Sunucu
# PORT=8472
# DEBUG=false
