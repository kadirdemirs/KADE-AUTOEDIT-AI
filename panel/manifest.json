{
  "manifestVersion": 5,
  "id": "com.kademedia.autoedit",
  "name": "KADE AutoEdit AI",
  "version": "1.0.0",
  "description": "AI-powered auto-editing panel for Premiere Pro",
  "author": "Kade Media",
  "main": "index.html",
  "entrypoints": [
    {
      "type": "panel",
      "id": "mainPanel",
      "label": { "default": "KADE AutoEdit" },
      "minimumSize": { "width": 230, "height": 300 },
      "maximumSize": { "width": 2000, "height": 2000 },
      "preferredDockedSize": { "width": 380, "height": 720 },
      "preferredFloatingSize": { "width": 380, "height": 720 }
    }
  ],
  "requiredPermissions": {
    "clipboard": "readAndWrite",
    "localFileSystem": "request",
    "network": {
      "domains": ["http://localhost:8472", "ws://localhost:8472"]
    },
    "ipc": {
      "enablePluginCommunication": true
    }
  },
  "host": [
    {
      "app": "premierepro",
      "minVersion": "25.2.0"
    }
  ]
}
